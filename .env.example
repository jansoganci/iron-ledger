# Month Proof — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# JWT secret: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Resend (email)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=reports@yourdomain.com
# Note: Resend requires a verified sender domain
# Sandbox mode has daily send limits — verify domain before demo day

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
# Note: Add your Vercel URL here for production: https://your-app.vercel.app

# Demo
DEMO_USER_EMAIL=demo@dronedemo.com
# The demo user is created manually in Supabase Auth dashboard before demo day.
# company_id is resolved server-side from companies.owner_id = auth.uid() — never
# sent by the client, never hardcoded in env.

# Railway (production only)
# PORT is set automatically by Railway — do not override locally
